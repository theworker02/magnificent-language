class Car {
  func init(name: string, speed: number) {
    self.name = name
    self.speed = speed
  }

  func drive(): void {
    print(self.name + " is driving at " + self.speed + " mph")
  }

  func describe(): string {
    return "Car(" + self.name + ", " + self.speed + ")"
  }
}

let car: Car = Car("Roadster", 88)
car.drive()
print(car.describe())
